<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>VidConnect</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="stylesheet" href="style.css" />
    <script src="/socket.io/socket.io.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <script src="/vendor/peerjs/peerjs.min.js"></script>
    <script>
      const ROOM_ID = "<%= roomId %>";
    </script>
  </head>
  <body>
    <!-- Pre-join lobby -->
    <div id="lobby" class="lobby">
      <div class="lobby__orbs" aria-hidden="true"><span></span><span></span><span></span></div>
      <div class="lobby__layout">
        <section class="lobby__hero">
          <h1 class="brand brand--lg"><i class="fas fa-video"></i> VidConnect</h1>
          <h2 id="lobbyGreeting" class="lobby__greeting">Welcome</h2>
          <p class="lobby__tagline">
            Fast, private video meetings that run right in your browser.
            No downloads, no sign-ups &mdash; just share the link.
          </p>
          <ul class="lobby__features">
            <li><i class="fas fa-shield-halved"></i> Peer-to-peer encrypted video</li>
            <li><i class="fas fa-desktop"></i> One-click screen sharing</li>
            <li><i class="fas fa-comments"></i> In-call messaging</li>
          </ul>
          <p class="lobby__dev">
            Developed by
            <a href="https://www.linkedin.com/in/sarwankumar-swe/" target="_blank" rel="noopener">
              <i class="fab fa-linkedin"></i> Sarwan Kumar
            </a>
          </p>
        </section>
        <div class="lobby__card">
          <!-- Panel: create or join -->
          <div id="panelChoice" class="lobby__panel">
            <h3 class="panel__title">Start or join a meeting</h3>
            <button id="createMeetingBtn" class="option-card">
              <span class="option-card__icon"><i class="fas fa-video"></i></span>
              <span class="option-card__body">
                <span class="option-card__label">Create meeting</span>
                <span class="option-card__desc">Start a new meeting and invite others</span>
              </span>
              <i class="fas fa-chevron-right option-card__arrow"></i>
            </button>
            <button id="joinMeetingBtn" class="option-card">
              <span class="option-card__icon"><i class="fas fa-right-to-bracket"></i></span>
              <span class="option-card__body">
                <span class="option-card__label">Join meeting</span>
                <span class="option-card__desc">Enter a meeting link shared with you</span>
              </span>
              <i class="fas fa-chevron-right option-card__arrow"></i>
            </button>
          </div>

          <!-- Panel: join with a link -->
          <div id="panelJoin" class="lobby__panel">
            <div class="panel__head">
              <button id="joinBackBtn" class="panel__back" title="Back"><i class="fas fa-arrow-left"></i></button>
              <h3 class="panel__title">Join a meeting</h3>
            </div>
            <p class="lobby__subtitle">Paste the meeting link you received</p>
            <input id="joinLinkInput" type="text" placeholder="Paste meeting link here" autocomplete="off" />
            <p id="joinLinkError" class="lobby__error hidden"></p>
            <button id="joinLinkBtn" class="btn btn--primary">Continue</button>
          </div>

          <!-- Panel: camera/name setup -->
          <div id="panelSetup" class="lobby__panel">
            <div class="panel__head">
              <button id="setupBackBtn" class="panel__back" title="Back"><i class="fas fa-arrow-left"></i></button>
              <h3 id="setupTitle" class="panel__title">Ready to join?</h3>
            </div>
            <div class="lobby__preview">
              <video id="lobbyPreview" autoplay muted playsinline class="mirrored"></video>
              <div id="lobbyPreviewOff" class="lobby__preview-off hidden">
                <i class="fas fa-video-slash"></i>
                <span id="lobbyPreviewOffText">Camera unavailable</span>
              </div>
              <div class="lobby__preview-controls">
                <button id="lobbyMicBtn" class="preview-btn" title="Toggle microphone">
                  <i class="fas fa-microphone"></i>
                </button>
                <button id="lobbyCamBtn" class="preview-btn" title="Toggle camera">
                  <i class="fas fa-video"></i>
                </button>
              </div>
            </div>
            <p id="lobbyError" class="lobby__error hidden"></p>
            <input id="lobbyName" type="text" maxlength="30" placeholder="Enter your name" autocomplete="off" />
            <button id="joinBtn" class="btn btn--primary" disabled>
              <span class="btn__spinner"></span><span id="joinBtnText">Connecting&hellip;</span>
            </button>
            <p id="setupStatus" class="lobby__status hidden"></p>
          </div>
        </div>
      </div>
    </div>

    <!-- Host notifications: people asking to join -->
    <div id="admitRequests" class="admit-stack"></div>

    <!-- Meeting -->
    <div id="app" class="app chat-open hidden">
      <header class="header">
        <div class="brand"><i class="fas fa-video"></i> VidConnect</div>
        <div class="header__info">
          <span id="participantCount" title="Participants"><i class="fas fa-user-group"></i> 1</span>
        </div>
      </header>
      <main class="main">
        <section class="stage">
          <div id="video-grid"></div>
          <div class="controls">
            <button id="muteButton" class="control-btn" title="Mute / unmute microphone">
              <i class="fas fa-microphone"></i>
            </button>
            <button id="stopVideo" class="control-btn" title="Turn camera on / off">
              <i class="fas fa-video"></i>
            </button>
            <button id="screenShareBtn" class="control-btn" title="Share your screen">
              <i class="fas fa-desktop"></i>
            </button>
            <button id="chatToggle" class="control-btn" title="Toggle chat">
              <i class="fas fa-comment"></i>
            </button>
            <button id="inviteButton" class="control-btn" title="Copy invite link">
              <i class="fas fa-user-plus"></i>
            </button>
            <button id="leaveBtn" class="control-btn control-btn--danger" title="Leave meeting">
              <i class="fas fa-phone-slash"></i>
            </button>
          </div>
        </section>
        <aside id="chatPanel" class="chat">
          <div class="chat__header">
            <span>In-call messages</span>
            <button id="chatClose" class="chat__close" title="Close chat"><i class="fas fa-times"></i></button>
          </div>
          <div id="chatWindow" class="chat__window">
            <div class="messages"></div>
          </div>
          <div class="chat__composer">
            <input id="chat_message" type="text" autocomplete="off" placeholder="Send a message&hellip;" />
            <button id="send" class="chat__send" title="Send"><i class="fas fa-paper-plane"></i></button>
          </div>
        </aside>
      </main>
    </div>

    <div id="toast" class="toast"></div>

    <script src="script.js"></script>
  </body>
</html>
